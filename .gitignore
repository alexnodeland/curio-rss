# Rust / Cargo (workspace root)
/target/

# Desktop head (apps/desktop — outside the cargo workspace until Phase 4)
node_modules/
apps/desktop/.svelte-kit/
apps/desktop/build/
apps/desktop/dist/
apps/desktop/coverage/
apps/desktop/src-tauri/target/
apps/desktop/src-tauri/bin/
apps/desktop/src-tauri/gen/

