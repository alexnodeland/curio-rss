{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cargo: test",
            "type": "shell",
            "command": "cargo test --workspace",
            "problemMatcher": ["$rustc"],
            "group": {
                "kind": "test",
                "isDefault": true
            }
        },
        {
            "label": "cargo: clippy",
            "type": "shell",
            "command": "cargo clippy --workspace --all-targets -- -D warnings",
            "problemMatcher": ["$rustc"],
            "group": "build"
        },
        {
            "label": "just: ci",
            "type": "shell",
            "command": "just ci",
            "problemMatcher": ["$rustc"]
        }
    ]
}
