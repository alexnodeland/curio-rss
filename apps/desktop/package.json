{
    "name": "curio-desktop",
    "version": "0.1.0",
    "description": "Curio's desktop head — SvelteKit frontend for the Tauri shell over curio-core",
    "type": "module",
    "scripts": {
        "dev": "vite dev",
        "build": "vite build",
        "preview": "vite preview",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --fail-on-warnings",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "test": "svelte-kit sync && vitest run",
        "test:watch": "svelte-kit sync && vitest",
        "test:coverage": "svelte-kit sync && vitest run --coverage",
        "lint": "biome check .",
        "lint:eslint": "eslint --max-warnings 0 .",
        "lint:fix": "biome check --write .",
        "format": "biome format --write .",
        "tauri": "tauri"
    },
    "devDependencies": {
        "@biomejs/biome": "^1.9.0",
        "@sveltejs/adapter-static": "^3.0.1",
        "@sveltejs/kit": "^2.0.0",
        "@sveltejs/vite-plugin-svelte": "^4.0.4",
        "@tauri-apps/cli": "^2.0.0",
        "@testing-library/svelte": "^5.0.0",
        "@types/node": "^20.10.0",
        "@typescript-eslint/parser": "^8.62.1",
        "@vitest/coverage-v8": "^2.0.0",
        "eslint": "^9.39.4",
        "eslint-plugin-svelte": "^3.20.0",
        "jsdom": "^24.0.0",
        "svelte": "^5.0.0",
        "svelte-check": "^4.0.0",
        "typescript": "^5.3.0",
        "vite": "^5.0.0",
        "vitest": "^2.0.0"
    },
    "dependencies": {
        "@tauri-apps/api": "^2.0.0",
        "@tauri-apps/plugin-opener": "^2.5.4",
        "dompurify": "^3.4.11"
    }
}
