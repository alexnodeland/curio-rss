{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Curio",
  "version": "0.4.0",
  "identifier": "io.github.alexnodeland.curio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Curio",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' asset: http://asset.localhost data:",
        "media-src": "'self' asset: http://asset.localhost",
        "frame-src": "https://www.youtube-nocookie.com",
        "connect-src": "ipc: http://ipc.localhost",
        "object-src": "'none'",
        "base-uri": "'none'"
      },
      "assetProtocol": {
        "enable": true,
        "scope": ["$CACHE/curio/images/**"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI5OEMwMEY2RjNEQTE0RTUKUldUbEZOcno5Z0NNS1lpR0E2Y3Q4MUd1eXord1hWb1ErOTUrNk84YlhIdCt6NlBPNTJNeWIwMXQK",
      "endpoints": [
        "https://github.com/alexnodeland/curio-rss/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
