{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Curio Reader",
    "version": "0.1.0",
    "identifier": "com.curio-reader.app",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../build"
    },
    "app": {
        "withGlobalTauri": false,
        "windows": [
            {
                "title": "Curio Reader",
                "width": 1200,
                "height": 800,
                "minWidth": 800,
                "minHeight": 600,
                "resizable": true,
                "fullscreen": false,
                "transparent": false,
                "decorations": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png"]
    }
}
